# =============================================================================
# Required
# =============================================================================

# Your Spotify app's client id and secret.
# Create an app at https://developer.spotify.com/dashboard, then copy the
# "Client ID" and "Client secret" from the app's settings page.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Long-lived OAuth refresh token for your Spotify account.
# Leave blank initially — `npm run bootstrap-auth` will mint one for you
# (it opens the Spotify authorize page, then prints the token to the console).
# Re-run bootstrap-auth whenever you change OAuth scopes.
SPOTIFY_REFRESH_TOKEN=

# Spotify id of the playlist that gets rewritten on every run.
# Leave blank initially — `bootstrap-auth` will create a fresh private
# playlist and print its id. To target an existing playlist instead, paste
# the id from its share URL: open.spotify.com/playlist/<this part>
SPOTIFY_PLAYLIST_ID=

# =============================================================================
# Optional
# =============================================================================

# OAuth redirect URI. Must match a redirect URI registered in your Spotify app.
# Default: http://127.0.0.1:8888/callback
# SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback

# Path to the TOML file listing eligible podcast shows.
# Default: podcasts.toml (in the repo root)
# PODCASTS_CONFIG_PATH=podcasts.toml

# Where to persist the user-playlist tracks cache (keyed by playlist id +
# snapshot id, so it invalidates automatically when a playlist changes).
# Default: .cache/spotify-playlist-tracks.json
# SPOTIFY_PLAYLIST_TRACKS_CACHE_PATH=.cache/spotify-playlist-tracks.json

# ListenBrainz user token to pull in collaborative-filter recommendations as
# an extra song source. Get one at https://listenbrainz.org/profile/.
# When unset, ListenBrainz is skipped entirely (no error).
# LISTENBRAINZ_USER_TOKEN=

# Last.fm API key to mix in discoveries from Last.fm's similarity graph
# (track.getSimilar / artist.getSimilar). Free, no OAuth — register at
# https://www.last.fm/api/account/create.
# When unset, Last.fm discovery is skipped entirely (no error).
# LASTFM_API_KEY=

# Where to persist the Last.fm → Spotify track resolution cache.
# Default: .cache/lastfm-spotify-tracks.json
# LASTFM_SPOTIFY_CACHE_PATH=.cache/lastfm-spotify-tracks.json
